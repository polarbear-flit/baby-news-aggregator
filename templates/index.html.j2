<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Baby News Aggregator</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    .card-hover { transition: box-shadow 0.2s; }
    .card-hover:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.12); }
    .tag { display: inline-block; padding: 2px 8px; border-radius: 9999px; font-size: 0.72rem; margin: 2px; }
    .filter-btn.active { background-color: #6366f1; color: #fff; }
    .article-item { transition: opacity 0.2s; }
    .article-item.hidden { display: none; }
  </style>
</head>
<body class="bg-gray-50 text-gray-800 min-h-screen">

  <!-- ヘッダー -->
  <header class="bg-indigo-600 text-white py-6 shadow">
    <div class="max-w-6xl mx-auto px-4">
      <h1 class="text-2xl font-bold">👶 Baby News Aggregator</h1>
      <p class="text-indigo-200 text-sm mt-1">生成日時: {{ generated_at }}</p>
    </div>
  </header>

  <main class="max-w-6xl mx-auto px-4 py-8 space-y-10">

    <!-- エグゼクティブサマリー -->
    <section>
      <h2 class="text-xl font-semibold mb-3 border-b pb-2">📋 エグゼクティブサマリー</h2>
      <div class="bg-white rounded-xl shadow p-5 space-y-2">
        {% for insight in analysis.overall_insights %}
        <div class="flex items-start gap-2">
          <span class="text-indigo-500 mt-0.5">▸</span>
          <p>{{ insight }}</p>
        </div>
        {% endfor %}
      </div>
    </section>

    <!-- グラフセクション -->
    <section class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- キーワード頻度棒グラフ -->
      <div class="bg-white rounded-xl shadow p-5">
        <h3 class="font-semibold mb-4 text-gray-700">🔑 キーワード頻度 TOP20</h3>
        <canvas id="keywordChart" height="260"></canvas>
      </div>
      <!-- カテゴリ別ドーナツグラフ -->
      <div class="bg-white rounded-xl shadow p-5">
        <h3 class="font-semibold mb-4 text-gray-700">🗂 カテゴリ別記事数</h3>
        <canvas id="categoryChart" height="260"></canvas>
      </div>
    </section>

    <!-- トレンドキーワード -->
    <section>
      <h2 class="text-xl font-semibold mb-3 border-b pb-2">📈 急上昇キーワード</h2>
      <div class="flex flex-wrap gap-3">
        {% for t in analysis.trending %}
        <div class="bg-indigo-50 border border-indigo-200 rounded-lg px-4 py-2 text-sm">
          <span class="font-bold text-indigo-700">{{ t.keyword }}</span>
          <span class="ml-2 text-gray-500">{{ t.count }}件</span>
          {% if t.rate > 0 %}
          <span class="ml-1 text-green-600 text-xs">↑{{ (t.rate * 100) | int }}%</span>
          {% endif %}
        </div>
        {% else %}
        <p class="text-gray-400 text-sm">トレンドデータがまだありません。</p>
        {% endfor %}
      </div>
    </section>

    <!-- カテゴリ別インサイト -->
    <section>
      <h2 class="text-xl font-semibold mb-3 border-b pb-2">💡 カテゴリ別インサイト</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {% for cat, insight in analysis.category_insights.items() %}
        <div class="bg-white rounded-xl shadow card-hover p-4">
          <p class="text-sm text-gray-700 leading-relaxed">{{ insight }}</p>
        </div>
        {% endfor %}
      </div>
    </section>

    <!-- ニュース一覧 -->
    <section>
      <h2 class="text-xl font-semibold mb-3 border-b pb-2">📰 ニュース一覧（{{ articles | length }}件）</h2>

      <!-- カテゴリフィルターボタン -->
      <div class="flex flex-wrap gap-2 mb-5" id="filterBtns">
        <button class="filter-btn active px-3 py-1 rounded-full border text-sm" data-cat="all">すべて</button>
        {% for cat, label in analysis.category_label.items() %}
        <button class="filter-btn px-3 py-1 rounded-full border text-sm bg-white" data-cat="{{ cat }}">{{ label }}</button>
        {% endfor %}
      </div>

      <!-- 記事リスト -->
      <div class="space-y-3" id="articleList">
        {% for article in articles %}
        {%- set ns = namespace(cats=[]) -%}
        {%- for cat, kw_list in analysis.cat_keywords.items() -%}
          {%- for kw in article.matched_keywords -%}
            {%- if kw in kw_list and cat not in ns.cats -%}
              {%- set ns.cats = ns.cats + [cat] -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endfor -%}
        <div class="article-item bg-white rounded-xl shadow card-hover p-4" data-cat-groups="{{ ns.cats | join(' ') }}">
          <div class="flex items-start justify-between gap-3">
            <div class="flex-1 min-w-0">
              <a href="{{ article.url }}" target="_blank" rel="noopener"
                 class="font-semibold text-indigo-700 hover:underline line-clamp-2 leading-snug">
                {{ article.title }}
              </a>
              {% if article.summary %}
              <p class="text-gray-500 text-sm mt-1 line-clamp-2">{{ article.summary }}</p>
              {% endif %}
              <div class="flex flex-wrap items-center gap-2 mt-2 text-xs text-gray-400">
                <span>{{ article.source_name }}</span>
                <span>·</span>
                <span>{{ article.published[:10] }}</span>
                <span>·</span>
                <span class="px-1.5 py-0.5 rounded bg-gray-100">{{ "🇯🇵" if article.language == "ja" else "🇺🇸" }}</span>
              </div>
            </div>
            {% if article.score is defined and article.score >= 5 %}
            <span class="shrink-0 bg-red-100 text-red-700 text-xs font-bold px-2 py-1 rounded">HOT</span>
            {% endif %}
          </div>
          {% if article.matched_keywords %}
          <div class="mt-2">
            {% for kw in article.matched_keywords[:6] %}
            <span class="tag bg-indigo-50 text-indigo-600 border border-indigo-100">{{ kw }}</span>
            {% endfor %}
          </div>
          {% endif %}
        </div>
        {% else %}
        <p class="text-gray-400 text-center py-10">記事が見つかりませんでした。</p>
        {% endfor %}
      </div>
    </section>

  </main>

  <footer class="text-center text-xs text-gray-400 py-6">
    Baby News Aggregator — 自動生成レポート {{ generated_at }}
  </footer>

  <script>
    // キーワード頻度棒グラフ
    const kwData = {{ analysis.keyword_freq | tojson }};
    const kwLabels = Object.keys(kwData);
    const kwValues = Object.values(kwData);
    new Chart(document.getElementById('keywordChart'), {
      type: 'bar',
      data: {
        labels: kwLabels,
        datasets: [{
          label: '記事数',
          data: kwValues,
          backgroundColor: 'rgba(99, 102, 241, 0.7)',
          borderRadius: 4,
        }]
      },
      options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
          x: { ticks: { font: { size: 10 } } },
          y: { beginAtZero: true, ticks: { stepSize: 1 } }
        }
      }
    });

    // カテゴリ別ドーナツグラフ
    const catData = {{ analysis.category_freq | tojson }};
    const catLabels = Object.keys(catData);
    const catValues = Object.values(catData);
    const catColors = ['#6366f1','#f59e0b','#10b981','#3b82f6','#ec4899','#8b5cf6','#14b8a6'];
    new Chart(document.getElementById('categoryChart'), {
      type: 'doughnut',
      data: {
        labels: catLabels,
        datasets: [{
          data: catValues,
          backgroundColor: catColors.slice(0, catLabels.length),
          hoverOffset: 6,
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { position: 'bottom', labels: { font: { size: 11 } } }
        }
      }
    });

    // カテゴリフィルター
    const filterBtns = document.querySelectorAll('.filter-btn');
    const articleItems = document.querySelectorAll('.article-item');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const cat = btn.dataset.cat;
        articleItems.forEach(item => {
          if (cat === 'all') {
            item.classList.remove('hidden');
          } else {
            const groups = (item.dataset.catGroups || '').trim().split(/\s+/);
            item.classList.toggle('hidden', !groups.includes(cat));
          }
        });
      });
    });
  </script>
</body>
</html>
